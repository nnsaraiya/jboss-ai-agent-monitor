# ── .env.example ─────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values for local development.
# In OpenShift, these are set via ConfigMap and Secret (see k8s/).
# ─────────────────────────────────────────────────────────────────────────────

# OpenShift / Kubernetes
JBOSS_NAMESPACE=jboss-production
JBOSS_LABEL_SELECTOR=app.kubernetes.io/managed-by=wildfly-operator
JBOSS_INSTANCE_NAME=

# Monitoring intervals
CHECK_INTERVAL_SECONDS=60
HEALTH_CHECK_TIMEOUT=10

# Health endpoint — leave empty for auto-discovery
HEALTH_CHECK_URLS=
HEALTH_CHECK_PATH=/health/ready

# Log monitoring
LOG_TAIL_LINES=300
LOG_ERROR_PATTERNS=SEVERE,OutOfMemoryError,DeploymentException,Caused by:

# AlertManager / Prometheus (in-cluster defaults)
ALERTMANAGER_URL=http://alertmanager-main.openshift-monitoring.svc.cluster.local:9093
PROMETHEUS_URL=http://prometheus-k8s.openshift-monitoring.svc.cluster.local:9090
ALERT_NAME_FILTER=WildFly|JBoss|EAP|Helidon

# JIRA (required)
JIRA_URL=https://your-org.atlassian.net
JIRA_USER=your-email@example.com
JIRA_TOKEN=your-jira-api-token
JIRA_PROJECT_KEY=OPS
JIRA_ISSUE_TYPE=Task
JIRA_LABELS=jboss,openshift,automated

# RHOAI (required)
# External route URL of the RHOAI model serving endpoint (must end in /v1)
# e.g. https://llama-32-3b-instruct-my-first-model.apps.<rhoai-cluster>/v1
RHOAI_API_URL=https://<model-name>-<namespace>.apps.<rhoai-cluster>/v1
# Token from the RHOAI cluster: oc login <rhoai-cluster> && oc whoami -t
RHOAI_API_KEY=your-rhoai-cluster-token
RHOAI_MODEL_NAME=llama-32-3b-instruct
RHOAI_MAX_TOKENS=2048

# Deduplication
DEDUP_WINDOW_MINUTES=120

# Feature flags (all on by default)
ENABLE_POD_MONITOR=true
ENABLE_ALERT_MONITOR=true
ENABLE_LOG_MONITOR=true
ENABLE_HEALTH_MONITOR=true

# Logging
LOG_LEVEL=INFO
